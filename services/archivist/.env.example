# Database (use individual vars or DATABASE_URL — URL takes precedence if set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rune
POSTGRES_PASSWORD=rune_password
POSTGRES_DB=rune_db
# DATABASE_URL=postgresql://rune:rune_password@localhost:5432/rune_db

# RabbitMQ (use individual vars or RABBITMQ_URL — URL takes precedence if set)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rune
RABBITMQ_PASSWORD=rune_password
# RABBITMQ_URL=amqp://rune:rune_password@localhost:5672/

# RabbitMQ topology
RABBITMQ_EXCHANGE=workflows
RABBITMQ_QUEUE=workflow.completion.recorder
RABBITMQ_ROUTING_KEY=workflow.completion
RABBITMQ_PREFETCH=10
