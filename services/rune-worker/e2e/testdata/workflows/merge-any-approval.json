    },
    {
      "id": "e3",
      "source": "if-approval",
      "sourceHandle": "false",
      "target": "log-auto",
      "type": "default"
    },
    {"id": "e4", "source": "log-manager", "target": "merge-approval", "type": "default"},
    {"id": "e5", "source": "log-auto", "target": "merge-approval", "type": "default"},
