      "type": "http",
      "position": {"x": 280, "y": 40},
      "data": {
        "label": "FetchApproval",
        "method": "GET",
        "url": "https://dummyjson.com/approvals/manager",
        "timeout": 30,
        "retry": 0,
        "retry_delay": 0,
        "raise_on_status": "4xx,5xx"
      }
