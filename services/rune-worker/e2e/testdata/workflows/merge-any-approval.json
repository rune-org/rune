      "type": "if",
      "position": {"x": 560, "y": 40},
      "data": {"label": "ApprovalGate", "expression": "$FetchApproval.body.source == 'manager'"}
    },
    {
      "id": "log-manager",
      "type": "log",
      "position": {"x": 840, "y": 0},
      "data": {"label": "ManagerLog", "message": "Manager approved", "level": "info"}
    },
    {
      "id": "log-auto",
      "type": "log",
      "position": {"x": 840, "y": 80},
      "data": {"label": "AutoLog", "message": "Auto approved", "level": "info"}
    },
    {
      "id": "merge-approval",
      "type": "merge",
      "position": {"x": 1120, "y": 40},
      "data": {"label": "MergeApprovals", "wait_mode": "wait_for_any"}
    },
    {
      "id": "log-final",
      "type": "log",
      "position": {"x": 1400, "y": 40},
      "data": {"label": "FinalLog", "message": "Approval merged", "level": "info"}
